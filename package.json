{
  "name": "ipsi-inside",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:web": "turbo run dev --filter=@ipsi/web",
    "dev:admin": "turbo run dev --filter=@ipsi/admin",
    "db:types": "supabase gen types typescript --project-id nnyqvnhlczvuavfehoeq > packages/db/src/database.types.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
